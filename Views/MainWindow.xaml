<Window x:Class="Lab6.LibraryClient.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Library Client (MVVM)" Height="620" Width="1000" MinHeight="520" MinWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Background="#F9FAFB">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" Height="30" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Год" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewPublicationYear}" Height="30" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="AuthorId" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewAuthorId}" Height="30" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="GenreIds (через запятую)" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding GenreIdsInput}" Height="30" />
                </StackPanel>

                <Button Grid.Column="4" Content="Добавить" Command="{Binding AddBookCommand}" Width="110" Height="30" Margin="0,22,8,0" />
                <Button Grid.Column="5" Content="Обновить" Command="{Binding LoadBooksCommand}" Width="110" Height="30" Margin="0,22,0,0" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  Margin="0,12,0,12"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding BooksCollection}"
                  SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70" />
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Год" Binding="{Binding PublicationYear}" Width="90" />
                <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="220" />
                <DataGridTextColumn Header="Жанры" Binding="{Binding GenresText}" Width="260" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="2">
            <Button Content="Удалить выбранную" Command="{Binding DeleteBookCommand}" Width="170" Height="32" DockPanel.Dock="Right" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="14" />
        </DockPanel>
    </Grid>
</Window>
